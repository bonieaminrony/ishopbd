# ⚠️ NEVER put real credentials here. This is only a template.
# Copy this file to .env and fill in your real values.

# --- Email (Order Confirmation) ---
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ORDER_NOTIFY_EMAIL=your-notify-email@gmail.com

# --- Gemini AI ---
GEMINI_API_KEY=

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- SMS Service (BulkSMSBD) ---
SMS_API_KEY=
SMS_SENDER_ID=

# --- Master Admin Password (use a strong password!) ---
MASTER_ADMIN_PASSWORD=

# --- Steadfast Courier API ---
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# --- CORS (comma-separated, production only) ---
# Example: https://ishopbd.com,https://www.ishopbd.com
ALLOWED_ORIGINS=

# --- Server ---
PORT=3000
